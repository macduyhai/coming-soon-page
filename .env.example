# =============================================================
#  ANM&CNCHP — Biến môi trường
#  Copy file này:
#    - Phát triển local : cp .env.example .env.local
#    - Build production : cp .env.example .env.production
#  Không bao giờ commit .env.local hoặc .env.production lên git
# =============================================================

# ── Email signup endpoint ─────────────────────────────────────
# Để trống → chế độ UI-only (validate + hiển thị success state)
# Formspree : https://formspree.io  → tạo form rồi lấy ID
# Getform   : https://getform.io
# Fab-form  : https://fabform.io
NEXT_PUBLIC_SIGNUP_ENDPOINT=

# ── Logo URL ──────────────────────────────────────────────────
# URL ảnh logo hiển thị trên header
# Có thể dùng Vercel Blob, S3, CDN, hoặc đường dẫn tuyệt đối bất kỳ
NEXT_PUBLIC_LOGO_URL=https://uy8k8uapwfdqd2zs.public.blob.vercel-storage.com/images/Logo%20Bo%CC%A3%CC%82%20Co%CC%82ng%20An.svg

# ── Ngày ra mắt (countdown) ──────────────────────────────────
# Định dạng ISO 8601: YYYY-MM-DDTHH:mm:ssZ
# Ví dụ: 2026-10-01T00:00:00Z  (01/10/2026 lúc 00:00 UTC)
NEXT_PUBLIC_LAUNCH_DATE=2026-10-01T00:00:00Z
